# MedContractIntel — Environment Variables Template
# Copy to med-contract-site/.env on Day 2; populate from 1Password vault 'MedCI — Secrets'.
# Commit only .env.example (this file, renamed), NEVER commit .env.

# Anthropic — powers the analyzer
ANTHROPIC_API_KEY=

# Email (Resend)
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=noreply@medcontractintel.com

# Stripe (test mode Day 2, live mode Day 4 afternoon)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Database
DATABASE_URL=file:./med-contract.db

# Sentry
SENTRY_DSN=

# Kit (ConvertKit) — email list
KIT_API_KEY=
KIT_FORM_ID_CHECKLIST=

# App
NODE_ENV=production
PORT=3000
